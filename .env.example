# Ambiente
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Banco de Dados (MySQL/MariaDB)
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=parrot_db
DB_USER=root
DB_PASSWORD=20071998

# JWT
JWT_SECRET=development-secret-change-in-production
